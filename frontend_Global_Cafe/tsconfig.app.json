{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src", "../backend_Global_Cafe/src/reception/analisis.module.ts", "../backend_Global_Cafe/src/reception/analisis.service.ts", "../backend_Global_Cafe/src/reception/analisis.controller.ts", "../backend_Global_Cafe/src/reception/create-analisis.dto.ts"]
}
